<Window x:Class="TruckScale.Pos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource App.Title}" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" SnapsToDevicePixels="True" 
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="Auto"
        Style="{StaticResource MaterialDesignWindow}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}"
        Loaded="Window_Loaded"
        WindowState="Maximized"
        PreviewKeyDown="Window_PreviewKeyDown">

    <!-- ====== ResizeMode="NoResize" WindowStyle="None" RECURSOS DE ESTILO ====== -->
    <Window.Resources>

        <!-- ===== COLORES PERSONALIZADOS ===== -->

        <!-- Métodos de pago -->
        <SolidColorBrush x:Key="PaymentCashBrush"     Color="#FF2E7D32"/>
        <!-- Cash -->
        <SolidColorBrush x:Key="PaymentCardBrush"     Color="#FF1976D2"/>
        <!-- Card -->
        <SolidColorBrush x:Key="PaymentBusinessBrush" Color="#FFF9A825"/>
        <!-- Business Account -->

        <!-- Botón DONE -->
        <SolidColorBrush x:Key="DoneCtaBg"   Color="#FF00C853"/>
        <SolidColorBrush x:Key="DoneCtaBgHv" Color="#FF00B34A"/>

        <!-- ====== RECURSOS DE ESTILO ====== -->


        <!-- Título grande -->
        <Style x:Key="TitleLarge" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- TextBox alto y legible -->
        <Style x:Key="FieldBox" TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <!-- Botones -->
        <Style x:Key="PrimaryRaised" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="PrimaryOutlined" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Card MD3 -->
        <Style TargetType="{x:Type md:Card}">
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
            <Setter Property="md:ElevationAssist.Elevation" Value="Dp2"/>
        </Style>

        <!-- Botón de tecla -->
        <Style x:Key="KeypadButton" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment"   Value="Stretch"/>
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="Margin"    Value="6"/>
            <Setter Property="FontSize"  Value="18"/>
        </Style>

        <!-- Botón de importe rápido -->
        <Style x:Key="QuickAmountButton" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Margin"    Value="6"/>
            <Setter Property="Padding"   Value="12,8"/>
            <Setter Property="FontSize"  Value="16"/>
        </Style>

        <!-- ===== KPI / Ledger helpers ===== -->
        <Style x:Key="AmountText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LedgerLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Opacity" Value="0.75"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <Style x:Key="LedgerValue" TargetType="TextBlock" BasedOn="{StaticResource AmountText}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="12,2,0,2"/>
        </Style>

        <Style x:Key="KpiChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
        </Style>

        <Style x:Key="KpiCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Form helpers -->
        <Style x:Key="FormGrid" TargetType="Grid"/>
        <Style x:Key="FormSection" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <!-- TextBox de diálogo -->
        <Style x:Key="FieldBoxPro" TargetType="{x:Type TextBox}" BasedOn="{StaticResource FieldBox}">
            <Setter Property="md:TextFieldAssist.HasClearButton" Value="True"/>
            <Setter Property="md:TextFieldAssist.DecorationVisibility" Value="Hidden"/>
        </Style>

        <!-- Card modal -->
        <Style x:Key="ModalCard" TargetType="{x:Type md:Card}">
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Width" Value="820"/>
            <Setter Property="md:ElevationAssist.Elevation" Value="Dp8"/>
        </Style>

        <!-- Botones modal -->
        <Style x:Key="DialogPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryRaised}">
            <Setter Property="MinWidth" Value="96"/>
        </Style>
        <Style x:Key="DialogSecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryOutlined}">
            <Setter Property="MinWidth" Value="96"/>
        </Style>
        <SolidColorBrush x:Key="StartCtaBg"   Color="#2E7D32"/>
        <!-- green 800 -->
        <SolidColorBrush x:Key="StartCtaBgHv" Color="#1B5E20"/>
        <!-- green 900 -->
        <SolidColorBrush x:Key="StartCtaFg"   Color="#FFFFFF"/>
        <!-- Colores para WAIT (rojo) -->
        <SolidColorBrush x:Key="WaitCtaBg"   Color="#C62828"/>
        <!-- red 800 -->
        <SolidColorBrush x:Key="WaitCtaBgHv" Color="#B71C1C"/>
        <!-- red 900 -->

        <!-- Estilo botón peligro/cancelar (rojo, mismo tamaño que StartCTA) -->
        <Style x:Key="DangerCTA" TargetType="Button" BasedOn="{StaticResource PrimaryRaised}">
            <Setter Property="Foreground" Value="{StaticResource StartCtaFg}"/>
            <Setter Property="Background" Value="{StaticResource WaitCtaBg}"/>
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="MinHeight"  Value="56"/>
            <Setter Property="MinWidth"   Value="100"/>
            <Setter Property="Padding"    Value="16,14"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WaitCtaBgHv}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#7B0000"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo del botón Start -->
        <Style x:Key="StartCTA" TargetType="Button" BasedOn="{StaticResource PrimaryRaised}">
            <Setter Property="Foreground" Value="{StaticResource StartCtaFg}"/>
            <Setter Property="Background" Value="{StaticResource StartCtaBg}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="Padding" Value="22,14"/>
            <!-- Ojo: quitamos ShadowAssist.ShadowDepth -->
            <Setter Property="md:ButtonAssist.CornerRadius" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource StartCtaBgHv}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#184C1A"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DoneCTA"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryRaised}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource DoneCtaBg}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="MinWidth"  Value="240"/>
            <Setter Property="Padding"   Value="32,18"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="24"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DoneCtaBgHv}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#00A844"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProductOption" TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="MinHeight" Value="64"/>
            <Setter Property="Padding"   Value="14,10"/>
            <Setter Property="Margin"    Value="0,8,12,0"/>
            <Setter Property="FontSize"  Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <!-- Seleccionado -->
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background"  Value="{DynamicResource PrimaryHueMidBrush}"/>
                    <Setter Property="Foreground"  Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                </Trigger>
                <!-- Deshabilitado -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PaymentButton"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryOutlined}">
            <Setter Property="Margin" Value="12,0,0,0"/>
            <Setter Property="MinHeight" Value="60"/>
            <Setter Property="MinWidth"  Value="150"/>
            <Setter Property="Padding"   Value="22,12"/>
            <Setter Property="FontSize"  Value="19"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>

            <Style.Triggers>
                <!-- Estado normal: solo borde/texto con color por método -->
                <DataTrigger Binding="{Binding Code}" Value="cash">
                    <Setter Property="BorderBrush" Value="{StaticResource PaymentCashBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PaymentCashBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Code}" Value="card">
                    <Setter Property="BorderBrush" Value="{StaticResource PaymentCardBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PaymentCardBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Code}" Value="business">
                    <Setter Property="BorderBrush" Value="{StaticResource PaymentBusinessBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PaymentBusinessBrush}"/>
                </DataTrigger>

                <!-- Seleccionado (IsSelected=True) + code -> fondo sólido -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Code}"      Value="cash"/>
                        <Condition Binding="{Binding IsSelected}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background"  Value="{StaticResource PaymentCashBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PaymentCashBrush}"/>
                    <Setter Property="Foreground"  Value="White"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Code}"      Value="card"/>
                        <Condition Binding="{Binding IsSelected}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background"  Value="{StaticResource PaymentCardBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PaymentCardBrush}"/>
                    <Setter Property="Foreground"  Value="White"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Code}"      Value="business"/>
                        <Condition Binding="{Binding IsSelected}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background"  Value="{StaticResource PaymentBusinessBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PaymentBusinessBrush}"/>
                    <Setter Property="Foreground"  Value="Black"/>
                </MultiDataTrigger>

                <!-- Deshabilitado -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>



        <!-- Label para ejes -->
        <Style x:Key="AxleLabel" TargetType="Label">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Label para TOTAL -->
        <Style x:Key="AxleTotalLabel" TargetType="Label" BasedOn="{StaticResource AxleLabel}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground"
            Value="{DynamicResource PrimaryHueMidBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <!-- Dentro de <Window.Resources> o <md:DialogHost.Resources> -->
        <SolidColorBrush x:Key="TxPayActiveBg" Color="#2E7D32"/>
        <SolidColorBrush x:Key="TxPayActiveFg" Color="White"/>

        <Style x:Key="TxPayBtnBase" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="TxPayBtnActive" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{StaticResource TxPayActiveBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TxPayActiveFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="md:ElevationAssist.Elevation" Value="Dp2"/>
            <Setter Property="IsEnabled" Value="False"/>
            <!-- IMPORTANT: no hace nada si le dan click -->
        </Style>



    </Window.Resources>

    <md:DialogHost x:Name="RootDialog">
        <md:DrawerHost x:Name="RootDrawerHost">

            <!-- ===== Menú lateral ===== -->
            <md:DrawerHost.LeftDrawerContent>
                <StackPanel Margin="12" Width="240">
                    <TextBlock Text="{DynamicResource Menu.Title}" FontWeight="Bold" Margin="0,0,0,12"/>
                    <!--<Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="{DynamicResource Menu.NewTicket}" Margin="0,0,0,8"/>-->
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="Today's transactions" Margin="0,0,0,8" Click="OpenTodayTransactions_Click"/>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="Cash Closing History" Margin="0,0,0,8" Click="OpenCashClosingHistory_Click"/>
                    <!--<Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="{DynamicResource Menu.ScaleMonitor}" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="{DynamicResource Menu.Tickets}"/>-->
                </StackPanel>
            </md:DrawerHost.LeftDrawerContent>

            <!-- ===== Drawer derecho: Quick Actions (modo compacto) ===== -->
            <md:DrawerHost.RightDrawerContent>
                <StackPanel Margin="16" Width="240">
                    <TextBlock Text="{DynamicResource QuickActions}" FontWeight="SemiBold"
                               FontSize="15" Margin="0,0,0,16"/>
                    <Button x:Name="BtnFindDriverDrawer"
                            Style="{StaticResource PrimaryRaised}"
                            Content="Search driver"
                            FontSize="18" MinHeight="48"
                            Click="RegisterDriver_Click"/>
                </StackPanel>
            </md:DrawerHost.RightDrawerContent>

            <!-- ===== CONTENIDO ===== -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="47"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="73*"/>
                    <ColumnDefinition Width="1127*"/>
                </Grid.ColumnDefinitions>
                <!-- Top bar -->
                <md:ColorZone Mode="Standard" Padding="12" Height="56"
                              Background="{DynamicResource MaterialDesignPaper}" Grid.ColumnSpan="2" Grid.RowSpan="2">
                    <DockPanel LastChildFill="True">
                        <Button Content="☰" Width="40" Height="32" Margin="0,0,8,0" Click="ToggleDrawer_Click"/>
                        <TextBlock Text="{DynamicResource App.Title}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <!--<Button Content="{DynamicResource Theme.Toggle}" Click="ToggleTheme_Click" Margin="8,0"/>-->
                            <Button x:Name="BtnRightDrawerToggle"
                                    Visibility="Collapsed"
                                    Width="40" Height="32"
                                    Margin="0,0,4,0"
                                    Click="BtnRightDrawerToggle_Click"
                                    ToolTip="Quick Actions"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <md:PackIcon Kind="Tune" Width="18" Height="18"/>
                            </Button>
                            <Button x:Name="CloseCashButton" Content="Close cash" Margin="8,0,0,0" Click="CloseCashButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>

                            <Button x:Name="LogoutButton" Content="Log off" Click="Logout_Click" Margin="8,0"/>

                        </StackPanel>
                    </DockPanel>
                </md:ColorZone>

                <!-- Layout principal -->
                <Grid Margin="16,25,16,32" Grid.ColumnSpan="2" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <!-- Izquierda: Live weight -->
                        <ColumnDefinition Width="*"/>
                        <!-- Centro: formulario -->
                        <ColumnDefinition x:Name="RightColDef" Width="200"/>
                        <!-- Derecha: log (más angosta) -->
                    </Grid.ColumnDefinitions>

                    <!-- ===== COLUMNA IZQUIERDA ===== -->
                    <Grid Grid.Column="0" Margin="0,0,16,0" RenderTransformOrigin="0.509,0.562">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" MinHeight="491"/>
                            <RowDefinition Height="*" MinHeight="100"/>
                        </Grid.RowDefinitions>

                        <!-- MONITOR -->
                        <md:Card Grid.Row="0" Grid.RowSpan="2" Margin="0,0,0,58">
                            <StackPanel Margin="0,-2,0,2">
                                <TextBlock Text="{DynamicResource LiveWeight}" Style="{StaticResource TitleLarge}"/>
                                <Border Margin="0,8,0,12" Padding="12" CornerRadius="10"
                                        Background="{DynamicResource MaterialDesignCardBackground}" Height="125">
                                    <Viewbox Stretch="Uniform" Margin="0,0,0,20">
                                        <TextBlock x:Name="WeightText"
                                                   Text="0.0 lb"
                                                   FontSize="72"
                                                   FontWeight="SemiBold"
                                                   TextOptions.TextFormattingMode="Ideal"
                                                   HorizontalAlignment="Center"/>
                                    </Viewbox>
                                </Border>

                                <!-- Live axles (tiempo real, debajo del peso grande) -->
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="Axle 1" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtLiveAx1" Text="— lb" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="Axle 2" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtLiveAx2" Text="— lb" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="Axle 3" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtLiveAx3" Text="— lb" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Botón WAIT / OK (semáforo) -->
                                    <Button x:Name="OkButton"
                                        Grid.Row="0"
                                        Style="{StaticResource StartCTA}"
                                        Click="OkButton_Click"
                                        Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <md:PackIcon x:Name="OkButtonIcon" Kind="TimerSand" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="OkButtonLabel" Text="WAIT"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="NewTransactionButton"
                                        Grid.Row="1"
                                        Style="{StaticResource DangerCTA}"
                                        Content="New"
                                        Click="NewTransaction_Click"/>
                                </Grid>

                                <!-- Ejes por sesión -->
                                <!--
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="Ejes por sesión" Style="{StaticResource TitleLarge}" />
                                </StackPanel>
                                <Label x:Name="lblEje1" Style="{StaticResource AxleLabel}" Content="Axle 1: 0 lb"/>
                                <Label x:Name="lblEje2" Style="{StaticResource AxleLabel}" Content="Axle 2: 0 lb"/>
                                <Label x:Name="lblEje3" Style="{StaticResource AxleLabel}" Content="Axle 3: 0 lb"/>
                                <Label x:Name="lblUUID" Style="{StaticResource AxleTotalLabel}" Content="Total: 0 lb"/>-->
                            </StackPanel>
                        </md:Card>

                        <!-- STATUS (inferior izquierdo) -->
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- status compacto -->
                                <RowDefinition Height="0"/>
                                <!-- log viewer removido — logs van a C:\TruckScaleLogs\ -->
                            </Grid.RowDefinitions>

                            <!-- Status strip compacto (mismo comportamiento, menor padding) -->
                            <md:Card Grid.Row="0" x:Name="StatusCard" Padding="10,6" Margin="0,0,0,6">
                                <md:Card.Resources>
                                    <SolidColorBrush x:Key="StIdleBg" Color="#ECEFF1"/>
                                    <SolidColorBrush x:Key="StIdleBr" Color="#90A4AE"/>
                                    <SolidColorBrush x:Key="StIdleFg" Color="#37474F"/>

                                    <SolidColorBrush x:Key="StConnectedBg" Color="#E8F5E9"/>
                                    <SolidColorBrush x:Key="StConnectedBr" Color="#2E7D32"/>
                                    <SolidColorBrush x:Key="StConnectedFg" Color="#1B5E20"/>

                                    <SolidColorBrush x:Key="StConnectingBg" Color="#FFF8E1"/>
                                    <SolidColorBrush x:Key="StConnectingBr" Color="#F9A825"/>
                                    <SolidColorBrush x:Key="StConnectingFg" Color="#5D4037"/>

                                    <SolidColorBrush x:Key="StErrorBg" Color="#FFEBEE"/>
                                    <SolidColorBrush x:Key="StErrorBr" Color="#C62828"/>
                                    <SolidColorBrush x:Key="StErrorFg" Color="#B71C1C"/>
                                </md:Card.Resources>

                                <md:Card.Style>
                                    <Style TargetType="{x:Type md:Card}">
                                        <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="md:ElevationAssist.Elevation" Value="Dp2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=lblTemp, Path=Content}" Value="Waiting">
                                                <Setter Property="Background"  Value="{StaticResource StIdleBg}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource StIdleBr}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ElementName=lblTemp, Path=Content}" Value="Connected">
                                                <Setter Property="Background"  Value="{StaticResource StConnectedBg}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource StConnectedBr}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ElementName=lblTemp, Path=Content}" Value="Connecting">
                                                <Setter Property="Background"  Value="{StaticResource StConnectingBg}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource StConnectingBr}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ElementName=lblTemp, Path=Content}" Value="Error">
                                                <Setter Property="Background"  Value="{StaticResource StErrorBg}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource StErrorBr}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </md:Card.Style>

                                <Label x:Name="lblTemp"
                                       Content="Waiting"
                                       HorizontalContentAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold">
                                    <Label.Style>
                                        <Style TargetType="Label">
                                            <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Waiting">
                                                    <Setter Property="Foreground" Value="{StaticResource StIdleFg}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Connected">
                                                    <Setter Property="Foreground" Value="{StaticResource StConnectedFg}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Connecting">
                                                    <Setter Property="Foreground" Value="{StaticResource StConnectingFg}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Error">
                                                    <Setter Property="Foreground" Value="{StaticResource StErrorFg}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>
                            </md:Card>

                            <!-- Log viewer removido — logs van a C:\TruckScaleLogs\ -->
                        </Grid>

                        <Label x:Name="lblEstado"
                               Content="Label"
                               HorizontalAlignment="Center"
                               Margin="0,466,0,0"
                               Opacity="0.7"
                               FontStyle="Italic"
                               Grid.Row="1"
                               VerticalAlignment="Top"
                               Height="88"
                               Grid.RowSpan="2"
                               Width="284"/>
                    </Grid>

                    <!-- ===== COLUMNA CENTRAL (ahora ocupa cols 1+2) ===== -->
                    <Grid Grid.Column="1" Grid.ColumnSpan="2" x:Name="MidCol" Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Find Driver -->
                            <RowDefinition Height="Auto"/>
                            <!-- Service + resumen -->
                            <RowDefinition Height="Auto"/>
                            <!-- Payment method + DONE -->
                            <RowDefinition Height="*"/>
                            <!-- Denominations + Driver summary -->
                        </Grid.RowDefinitions>

                        <!-- ROW 0: Find Driver (movido desde columna derecha) -->
                        <md:Card Grid.Row="0" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="22"
                                            Height="22"
                                            CornerRadius="6"
                                            Background="{DynamicResource PrimaryHueMidBrush}"
                                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                            BorderThickness="2"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="1"
                                                   Foreground="Red"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Driver details"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="RegisterDriverButton"
                                        Style="{StaticResource PrimaryRaised}"
                                        Content="Search driver"
                                        Margin="0,12,0,0"
                                        FontSize="18"
                                        MinHeight="48"
                                        Click="RegisterDriver_Click"/>
                            </StackPanel>
                        </md:Card>

                        <!-- ROW 1: Service + Payment summary + Payments received + Balance -->
                        <md:Card Grid.Row="1" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.2*"/>
                                    <!-- Service -->
                                    <ColumnDefinition Width="1.6*"/>
                                    <!-- Payment summary -->
                                    <ColumnDefinition Width="4"/>
                                    <!-- Separador -->
                                    <ColumnDefinition Width="1.6*"/>
                                    <!-- Payments received -->
                                    <ColumnDefinition Width="1.2*"/>
                                    <!-- Balance -->
                                </Grid.ColumnDefinitions>

                                <!-- Service -->
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <!-- Título + Paso 2 -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                                        <Border Width="22"
                Height="22"
                CornerRadius="6"
                Background="{DynamicResource PrimaryHueMidBrush}"
                BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                BorderThickness="2"
                Margin="0,0,8,0">
                                            <TextBlock Text="2"
                       Foreground="Red"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="Service"
                   Style="{StaticResource TitleLarge}"
                   Margin="0"/>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ToggleButton x:Name="WeighToggle"
                                                      Grid.Column="0"
                                                      Style="{StaticResource ProductOption}"
                                                      Margin="0,0,8,0"
                                                      Checked="WeighToggle_Checked">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <md:PackIcon Kind="Scale" Width="20" Height="20" Margin="0,0,10,0"/>
                                                <TextBlock Text="Weigh" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </ToggleButton>

                                        <ToggleButton x:Name="ReweighToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ProductOption}"
                                                      Margin="8,0,0,0"
                                                      Checked="ReweighToggle_Checked">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <md:PackIcon Kind="History" Width="20" Height="20" Margin="0,0,2,0"/>
                                                <TextBlock Text="Reweigh" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </ToggleButton>
                                    </Grid>
                                </StackPanel>

                                <!-- Payment summary (ANTES: Order total) -->
                                <Border Grid.Column="1"
                                        Margin="12,0,12,0"
                                        Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Payment summary"
                                                   Style="{StaticResource FormSection}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TotalVentaBigText"
                                                   Text="$0.00"
                                                   FontSize="32"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Typography.NumeralAlignment="Tabular"/>
                                    </StackPanel>
                                </Border>

                                <!-- Separador visual -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource MaterialDesignDivider}"
                                        Margin="0,4,0,4"/>

                                <!-- Payments received -->
                                <Border Grid.Column="3"
                                        Margin="12,0,12,0"
                                        Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Payments received"
                                                   Style="{StaticResource FormSection}"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <ItemsControl x:Name="PagosList">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,2,0,2">
                                                            <TextBlock Text="{Binding Metodo}" />
                                                            <TextBlock Text="{Binding Monto, StringFormat={}{0:C}}"
                                                                       DockPanel.Dock="Right"
                                                                       Style="{StaticResource AmountText}"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Placeholder -->
                                            <TextBlock x:Name="PagosEmpty"
                                                       Text="{DynamicResource Payment.Empty}"
                                                       Opacity="0.6"
                                                       Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasItems, ElementName=PagosList}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Total recibido (OCULTO, para no romper code-behind) -->
                                            <TextBlock x:Name="PagoRecibidoText"
                                                       Style="{StaticResource AmountText}"
                                                       FontSize="16"
                                                       Margin="0,4,0,0"
                                                       Visibility="Collapsed"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Balance (Change) -->
                                <Border Grid.Column="4"
                                        Margin="12,0,0,0"
                                        Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Balance $"
                                                   Style="{StaticResource FormSection}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock x:Name="BalanceText"
                                                   Text="0.00"
                                                   Style="{StaticResource AmountText}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   FontSize="36"
                                                   Foreground="{StaticResource DoneCtaBg}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </md:Card>

                        <!-- ROW 2: Payment method + DONE -->
                        <md:Card Grid.Row="2"
                                 MinHeight="130"
                                 Margin="0,0,0,16"
                                 Padding="18,18,18,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Label + botones de método de pago -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <!-- Título -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Botones -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Referencia -->
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Label -->
                                    <!-- Label (Paso 3 + título) -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                        <Border Width="22"
            Height="22"
            CornerRadius="6"
            Background="{DynamicResource PrimaryHueMidBrush}"
            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
            BorderThickness="2"
            Margin="0,0,8,0">
                                            <TextBlock Text="3"
                   Foreground="red"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="{DynamicResource Payment.MethodTitle}"
               Style="{StaticResource TitleLarge}"
               Margin="0"
               VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Botones de método de pago -->
                                    <ItemsControl Grid.Row="1" x:Name="PaymentMethodsItems" ItemsSource="{Binding PaymentMethods, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="PaymentMethod_Click" Style="{StaticResource PaymentButton}" IsEnabled="{Binding IsEnabled}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <md:PackIcon Kind="{Binding IconKind}"  Width="18" Height="18" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>


                                    <!-- Referencia (Credit / Business account) -->
                                    <StackPanel x:Name="RefPanel"
                                        Grid.Row="2"
                                        Margin="0,12,0,0"
                                        Visibility="Collapsed">
                                        <TextBlock Text="{DynamicResource Reference}" Opacity="0.7"/>
                                        <TextBox x:Name="RefText" Style="{StaticResource FieldBox}" />
                                    </StackPanel>
                                </Grid>


                                <!-- Botón DONE súper grande y centrado -->
                                <Button x:Name="DoneButton"
                                        Grid.Column="1"
                                        Style="{StaticResource DoneCTA}"
                                        Margin="32,4,0,4"
                                        VerticalAlignment="Center"
                                        Click="DoneButton_Click">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <md:PackIcon Kind="CheckBold"
                                                     Width="22"
                                                     Height="22"
                                                     Margin="0,0,10,0"/>
                                        <TextBlock Text="DONE"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>

                            </Grid>
                        </md:Card>
                        <!-- ROW 3: Denominations (mitad) + Driver summary (mitad) -->
                        <Grid Grid.Row="3" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Denominations -->
                            <md:Card Grid.Column="0" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Denominations}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <ItemsControl x:Name="DenomsHost">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Tag="{Binding Amount}"
                    Content="{Binding Text}"
                    IsEnabled="{Binding IsEnabled}"
                    Click="Denom_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource QuickAmountButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuggested}" Value="True">
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter Property="Background" Value="{DynamicResource SecondaryHueMidBrush}"/>
                                                                    <Setter Property="Foreground" Value="Black"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </md:Card>



                            <!-- Driver summary en la otra mitad -->
                            <!-- Right column container -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">

                                <!-- Session Axles (moved here) -->
                                <md:Card x:Name="AxlesCard"
             Padding="22"
             UniformCornerRadius="12"
             Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                                            <md:PackIcon Kind="TruckOutline"
                             Width="24"
                             Height="24"
                             Opacity="0.9"
                             Margin="0,0,8,0"/>
                                            <TextBlock Text="Session axles"
                           FontWeight="SemiBold"
                           FontSize="16"
                           VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Separator Margin="0,4,0,10"/>

                                        <!-- KEEP SAME LABEL NAMES -->
                                        <Label x:Name="lblEje1" Style="{StaticResource AxleLabel}" Content="Axle 1: 0 lb"/>
                                        <Label x:Name="lblEje2" Style="{StaticResource AxleLabel}" Content="Axle 2: 0 lb"/>
                                        <Label x:Name="lblEje3" Style="{StaticResource AxleLabel}" Content="Axle 3: 0 lb"/>
                                        <Label x:Name="lblUUID" Style="{StaticResource AxleTotalLabel}" Content="Total: 0 lb"/>
                                    </StackPanel>
                                </md:Card>

                                <!-- Driver summary (YOUR ORIGINAL CARD, unchanged) -->
                                <md:Card x:Name="DriverCard"
             Margin="0,0,0,0"
             Padding="22"
             UniformCornerRadius="12"
             Visibility="Collapsed">
                                    <!-- pega aqui EXACTO tu contenido original -->
                                    <StackPanel>
                                        <!-- Header -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                                            <md:PackIcon Kind="AccountTie" Width="24" Height="24" Opacity="0.9" Margin="0,0,8,0"/>
                                            <TextBlock Text="Driver summary" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Separator Margin="0,4,0,10"/>

                                        <!-- NO CREDIT BANNER — visible only when available_credit <= 0 -->
                                        <Border x:Name="NoCreditBanner"
                                                Visibility="Collapsed"
                                                CornerRadius="6"
                                                Background="#FFEBEE"
                                                BorderBrush="#C62828"
                                                BorderThickness="1.5"
                                                Padding="12,10"
                                                Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <md:PackIcon Kind="AlertOctagon"
                                                             Width="22" Height="22"
                                                             Foreground="#C62828"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="NO CREDIT AVAILABLE"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="#C62828"/>
                                                    <TextBlock Text="This account cannot use Business Account"
                                                               FontSize="11"
                                                               Foreground="#B71C1C"
                                                               Opacity="0.85"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock x:Name="DriverNameText" Text="—" FontSize="22" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock Text="Account and service" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>

                                        <Grid Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <md:PackIcon Kind="AccountMultipleOutline" Width="16" Height="16" Opacity="0.75" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DriverAccountText" Text="Account: —" FontSize="14" Opacity="0.95"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <md:PackIcon Kind="PackageVariantClosed" Width="16" Height="16" Opacity="0.75" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DriverProductText" Text="Product: —" FontSize="14" Opacity="0.95"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <md:PackIcon Kind="License" Width="16" Height="16" Opacity="0.75" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DriverLicenseText" Text="License: —" FontSize="14" Opacity="0.95"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <md:PackIcon Kind="Car" Width="16" Height="16" Opacity="0.75" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DriverPlatesText" Text="Plates: —" FontSize="14" Opacity="0.95"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <md:PackIcon Kind="Truck" Width="16" Height="16" Opacity="0.75" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DriverUnitText" Text="Unit: —" FontSize="14" Opacity="0.95"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <md:PackIcon Kind="MapMarker" Width="16" Height="16" Opacity="0.75" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DriverAccountAddressText" Text="Address: —" FontSize="14" TextWrapping="Wrap" Opacity="0.9" MaxWidth="260"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </md:Card>

                            </StackPanel>



                        </Grid>
                    </Grid>

                    <!-- ===== COLUMNA DERECHA (reservada para code-behind responsive; sin contenido visual) ===== -->
                    <StackPanel Grid.Column="2" x:Name="RightCol"/>

                    <!-- BLOQUEO UI (cubre columnas 1 y 2) -->
                    <Grid Grid.Column="1" Grid.ColumnSpan="2" x:Name="UiBlocker" Visibility="Visible" IsHitTestVisible="True">
                        <Border CornerRadius="12" Background="#80FFFFFF" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <md:PackIcon Kind="Lock" Width="28" Height="28" Opacity="0.7" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding ElementName=lblTemp, Path=Content}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Scale is controlled automatically" Opacity="0.7" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>


                <!-- Barra de estado -->
                <DockPanel Height="28" VerticalAlignment="Bottom" Margin="8,0" Opacity="0.8" Grid.ColumnSpan="2" Grid.Row="1">
                    <TextBlock x:Name="ScaleStateText" Text="{DynamicResource Scale.Simulated}"/>
                    <TextBlock Text="   |   " />
                    <TextBlock>
                        <Run Text="{DynamicResource Operator}"/>    
                        <Run Text=": " />
                        <Run x:Name="OperatorNameRun" Text="admin"/>
                    </TextBlock>
                    <TextBlock Text="   |   " />
                    <TextBlock Text="{Binding ElementName=WeightText, Path=Text}" />

                    <!-- NUEVO: Indicador de sincronización -->
                    <TextBlock Text="   |   " />
                    <TextBlock x:Name="SyncStatusText" 
               Text="🟢 Sync: Active" 
               ToolTip="Ctrl+Alt+F9 for sync debug"/>
                </DockPanel>

                <!-- === SALE COMPLETED DIALOG (improved) === -->
                <md:DialogHost x:Name="SaleCompletedHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="100">
                    <md:DialogHost.DialogContent>
                        <Grid Width="660"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
                            <md:Card Padding="24"
                     md:ElevationAssist.Elevation="Dp4"
                     UniformCornerRadius="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <md:PackIcon Kind="CheckCircle"
                                     Width="34" Height="34"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="Sale completed"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Transaction finished successfully"
                                       Opacity=".65"
                                       FontSize="13"
                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- KPI row -->
                                    <Border Grid.Row="1" Margin="0,18,0,0" Padding="14" CornerRadius="12"
                            Background="{DynamicResource MaterialDesignPaper}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="Total" Opacity=".7" FontSize="13"/>
                                                <TextBlock x:Name="DlgSaleTotal" FontSize="24" FontWeight="Bold" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="Received" Opacity=".7" FontSize="13"/>
                                                <TextBlock x:Name="DlgSaleReceived" FontSize="24" FontWeight="Bold" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="Change" Opacity=".7" FontSize="13"/>
                                                <TextBlock x:Name="DlgSaleChange"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,2,0,0"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Ticket + spinner -->
                                    <Grid Grid.Row="2" Margin="0,18,0,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <md:PackIcon Grid.Column="0" Kind="ReceiptText" Width="22" Height="22" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="Printing ticket…" VerticalAlignment="Center" Opacity=".85"/>

                                        <ProgressBar Grid.Column="2"
                                     x:Name="DlgTicketProgress"
                                     IsIndeterminate="True"
                                     Width="180"
                                     Height="6"
                                     VerticalAlignment="Center"
                                     Margin="14,0,0,0"/>
                                    </Grid>

                                    <!-- Footer -->
                                    <Grid Grid.Row="3" Margin="0,22,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock x:Name="DlgSaleUid"
                                   Grid.Column="0"
                                   Opacity=".7"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button x:Name="DlgReprintBtn"
                                    Content="Reprint"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="44"
                                    MinWidth="130"
                                    FontSize="15"
                                    Padding="18,8"
                                    md:ButtonAssist.CornerRadius="10"
                                    Margin="0,0,10,0"/>

                                            <!--<Button x:Name="DlgCloseBtn"
                                    Content="Close"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Height="44"
                                    MinWidth="130"
                                    FontSize="15"
                                    Padding="18,8"
                                    md:ButtonAssist.CornerRadius="10"
                                    IsDefault="True"
                                    Background="{DynamicResource PrimaryHueMidBrush}"
                                    Foreground="White"/>-->
                                            <Button x:Name="DlgCloseBtn"
                                                        Content="Close"
                                                        Height="44"
                                                        MinWidth="130"
                                                        FontSize="15"
                                                        Padding="18,8"
                                                        md:ButtonAssist.CornerRadius="10"
                                                        IsDefault="True">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{x:Null}"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>


                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>


                <!-- === DRIVER SAVED DIALOG === -->
                <md:DialogHost x:Name="DriverSavedHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="100">
                    <md:DialogHost.DialogContent>
                        <Grid Width="480" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="18" md:ElevationAssist.Elevation="Dp2" UniformCornerRadius="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="BadgeAccount" Width="26" Height="26"  Foreground="{DynamicResource PrimaryHueMidBrush}"  Margin="0,0,8,0"/>
                                        <TextBlock Text="Driver saved" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock x:Name="DlgDrvName"  FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="DlgDrvExtra" Opacity=".8"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                        <Button x:Name="DlgDrvOkBtn" Content="OK" IsDefault="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <!-- === GENERIC ALERT DIALOG (CENTERED) === -->
                <md:DialogHost x:Name="AlertHost"
                   Grid.RowSpan="99"
                   Grid.ColumnSpan="99"
                   Panel.ZIndex="100">
                    <md:DialogHost.DialogContent>
                        <Grid Width="420"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
                            <md:Card Padding="18"
                     md:ElevationAssist.Elevation="Dp2"
                     UniformCornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Título + icono -->
                                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                                        <md:PackIcon x:Name="AlertIcon"
                                     Kind="InformationOutline"
                                     Width="26" Height="26"
                                     Margin="0,0,8,0"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                        <TextBlock x:Name="AlertTitle"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- Mensaje -->
                                    <TextBlock x:Name="AlertMessage"
                               Grid.Row="1"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                                    <!-- Botón OK -->
                                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                                        <Button x:Name="AlertOkButton"
                                MinWidth="80"
                                IsDefault="True"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <md:PackIcon Kind="Check"
                                             Width="18" Height="18"
                                             Margin="0,0,4,0"/>
                                                <TextBlock Text="OK"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <!-- ================== REWEIGH TICKET DIALOG ================== -->
                <md:DialogHost x:Name="ReweighHost" Identifier="ReweighHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="100">
                    <md:DialogHost.DialogContent>
                        <!-- Centered container -->
                        <Grid Width="620" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="24" md:ElevationAssist.Elevation="Dp2" UniformCornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Title -->
                                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,16">
                                        <md:PackIcon Kind="QrCodeScan"
                                     Width="32"
                                     Height="32"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                                        <TextBlock Text="Reweigh ticket"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Description (operator-friendly) -->
                                    <TextBlock Grid.Row="1"
                               Text="Scan the original ticket QR code or type the ticket number."
                               TextWrapping="Wrap"
                               Margin="0,0,0,18"
                               Opacity="0.8"/>

                                    <!-- Big input -->
                                    <TextBox Grid.Row="2"
                             x:Name="ReweighTicketInputTextBox"
                             md:HintAssist.Hint="Ticket number or QR code"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             md:TextFieldAssist.DecorationVisibility="Hidden"
                             Margin="0,0,0,18"
                             FontSize="18"
                             Height="56"
                             HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center"
                             TextWrapping="NoWrap"
                             PreviewTextInput="ReweighTicketInputTextBox_PreviewTextInput"
                             KeyDown="ReweighTicketInputTextBox_KeyDown"/>

                                    <!-- Buttons -->
                                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                Margin="0,0,8,0"
                                Padding="18,6"
                                Command="{x:Static md:DialogHost.CloseDialogCommand}"
                                CommandParameter="{x:Null}"
                                Click="ReweighCancelButton_Click"/>

                                        <Button Content="Continue"
                                Padding="18,6"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="ReweighAcceptButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <md:DialogHost x:Name="TodayTxHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="120">

                    <md:DialogHost.DialogContent>
                        <Grid Width="980" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="18" md:ElevationAssist.Elevation="Dp3" UniformCornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <!-- Header -->
                                    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,10">

                                        <!-- Close compacto (NO debe ser el último hijo) -->
                                        <Button DockPanel.Dock="Right"
                                                Click="CloseTodayTransactions_Click"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Height="34"
                                                MinWidth="88"
                                                Padding="14,0"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Content="Close"/>

                                        <!-- Título + subtítulo (este queda como el último y rellena) -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <md:PackIcon Kind="ReceiptText" Width="22" Height="22" Margin="0,0,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Today's transactions" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TodayTxSubtitle" Opacity=".65" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- separador sutil -->
                                    <Border Grid.Row="0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>


                                    <!-- Table -->
                                    <DataGrid x:Name="TodayTxGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              GridLinesVisibility="None"
                                              Margin="0,0,0,10"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow">
                                        <DataGrid.Columns>

                                            <DataGridTextColumn Header="Time"
                                                Binding="{Binding PrintedAt, StringFormat={}{0:HH:mm}}"
                                                Width="90"/>

                                            <DataGridTextColumn Header="Ticket"
                                                Binding="{Binding TicketNumber}"
                                                Width="140"/>

                                            <DataGridTextColumn Header="Service"
                                                Binding="{Binding ServiceDesc}"
                                                Width="*"/>

                                            <DataGridTextColumn Header="Total"
                                                Binding="{Binding Total, StringFormat={}{0:C}}"
                                                Width="120"/>

                                            <!-- Payment method buttons -->
                                            <DataGridTemplateColumn Header="Payment" Width="260">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                                            <!-- CASH -->
                                                            <Button Tag="cash" Click="ChangePaymentMethod_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource TxPayBtnBase}">
                                                                        <Setter Property="IsEnabled" Value="{Binding CanEditPayment}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding MethodCode}" Value="cash">
                                                                                <Setter Property="Background" Value="{StaticResource TxPayActiveBg}"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource TxPayActiveFg}"/>
                                                                                <Setter Property="BorderBrush" Value="{x:Null}"/>
                                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                                <!-- evita look disabled -->
                                                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                                                                <!-- no hace nada al click -->
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>

                                                                <StackPanel Orientation="Horizontal">
                                                                    <!-- Check solo cuando es el actual -->
                                                                    <md:PackIcon Kind="Check" Width="16" Height="16" Margin="0,0,6,0">
                                                                        <md:PackIcon.Style>
                                                                            <Style TargetType="md:PackIcon">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding MethodCode}" Value="cash">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </md:PackIcon.Style>
                                                                    </md:PackIcon>

                                                                    <md:PackIcon Kind="Cash" Width="16" Height="16" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="Cash"/>
                                                                </StackPanel>
                                                            </Button>

                                                            <!-- CARD -->
                                                            <Button Tag="card" Click="ChangePaymentMethod_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource TxPayBtnBase}">
                                                                        <Setter Property="IsEnabled" Value="{Binding CanEditPayment}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding MethodCode}" Value="card">
                                                                                <Setter Property="Background" Value="{StaticResource TxPayActiveBg}"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource TxPayActiveFg}"/>
                                                                                <Setter Property="BorderBrush" Value="{x:Null}"/>
                                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>

                                                                <StackPanel Orientation="Horizontal">
                                                                    <md:PackIcon Kind="Check" Width="16" Height="16" Margin="0,0,6,0">
                                                                        <md:PackIcon.Style>
                                                                            <Style TargetType="md:PackIcon">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding MethodCode}" Value="card">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </md:PackIcon.Style>
                                                                    </md:PackIcon>

                                                                    <md:PackIcon Kind="CreditCardOutline" Width="16" Height="16" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="Card"/>
                                                                </StackPanel>
                                                            </Button>

                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- VOID -->
                                            <!-- Actions -->
                                            <DataGridTemplateColumn Header="Actions" Width="240">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                                            <!-- REPRINT (icon-only) -->
                                                            <Button Click="ReprintTicket_Click"
                                                                ToolTip="Reprint"
                                                                Padding="0"
                                                                Width="44"
                                                                Height="36"
                                                                Margin="0,0,10,0"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}">
                                                                <md:PackIcon Kind="Printer" Width="18" Height="18"/>
                                                            </Button>


                                                            <!-- VOID -->
                                                            <Button Content="VOID"  Padding="14,4" Click="VoidSale_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                                        <Setter Property="IsEnabled" Value="{Binding CanVoid}"/>
                                                                        <Setter Property="MinWidth" Value="110"/>
                                                                        <Setter Property="Background" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="BorderBrush" Value="{x:Null}"/>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>

                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Footer hint -->
                                    <TextBlock Grid.Row="2" Opacity=".65" FontSize="12"
                               Text="Only Cash/Card changes are allowed. Business Account is excluded.">
                                    </TextBlock>

                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>
                <!--DialogHost para Missed Transaction Reason (dropdown)-->

                <md:DialogHost x:Name="MissedReasonHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="131">
                    <md:DialogHost.DialogContent>
                        <Grid Width="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="18" md:ElevationAssist.Elevation="Dp3" UniformCornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <md:PackIcon Kind="TruckAlert" Width="24" Height="24"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     Margin="0,0,8,0"/>
                                        <TextBlock Text="Missed transaction" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,0,0,14">
                                        <TextBlock Text="Reason" Opacity=".7" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="MissedReasonCombo"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="VoidReasonId"
                                                  MinHeight="40"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Padding="16,6"
                                                Margin="0,0,8,0"
                                                Click="MissedReasonCancel_Click"/>
                                        <Button Content="Confirm"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Padding="16,6"
                                                Click="MissedReasonConfirm_Click"/>
                                    </StackPanel>

                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <!--DialogHost para pedir Void Reason (dropdown)-->

                <md:DialogHost x:Name="VoidReasonHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="130">
                    <md:DialogHost.DialogContent>
                        <Grid Width="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="18" md:ElevationAssist.Elevation="Dp3" UniformCornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <md:PackIcon Kind="AlertCircleOutline" Width="24" Height="24"
                                     Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                     Margin="0,0,8,0"/>
                                        <TextBlock Text="Void sale" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,0,0,14">
                                        <TextBlock Text="Reason" Opacity=".7" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="VoidReasonCombo"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="VoidReasonId"
                                  MinHeight="40"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="16,6"
                                Margin="0,0,8,0"
                                Click="VoidReasonCancel_Click"/>
                                        <Button Content="Confirm VOID"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="16,6"
                                Background="{DynamicResource MaterialDesignValidationErrorBrush}"
                                Foreground="White"
                                Click="VoidReasonConfirm_Click"/>
                                    </StackPanel>

                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <!-- ================== CASH SESSION BLOCKER (cuando la caja es de otro user) ================== -->
                <Grid x:Name="CashSessionBlocker" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="140"  Visibility="Collapsed" IsHitTestVisible="True">
                    <Border Background="#AAFFFFFF">
                        <md:Card Width="760" Padding="24" md:ElevationAssist.Elevation="Dp6" UniformCornerRadius="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <md:PackIcon Kind="LockAlert" Width="30" Height="30"
                                 Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                 Margin="0,0,10,0"/>
                                    <TextBlock Text="Cash session already open"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock x:Name="CashSessionBlockerMessage" TextWrapping="Wrap" Opacity=".85" Margin="0,0,0,18"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Log off" MinWidth="140" Height="44" Style="{StaticResource MaterialDesignRaisedButton}" Click="Logout_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </md:Card>
                    </Border>
                </Grid>

                <!-- ================== OPEN CASH SESSION MODAL ================== -->
                <md:DialogHost x:Name="CashOpenHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="150">
                    <md:DialogHost.DialogContent>
                        <Grid Width="820" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="24" md:ElevationAssist.Elevation="Dp6" UniformCornerRadius="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                        <md:PackIcon Kind="CashRegister" Width="30" Height="30"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="Open cash session"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Enter the opening cash amount to start the shift."
                                       Opacity=".65"
                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Opening cash -->
                                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                        <TextBlock Text="Opening cash (USD)" Opacity=".7" Margin="0,0,0,6"/>
                                        <TextBox x:Name="OpeningCashTextBox"
                                             FontSize="18"
                                             Height="52"
                                             md:HintAssist.Hint="0.00"
                                             md:TextFieldAssist.DecorationVisibility="Hidden"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             PreviewTextInput="DecimalOnly_PreviewTextInput"
                                             DataObject.Pasting="DecimalOnly_Pasting"
                                             GotKeyboardFocus="Money_GotKeyboardFocus"
                                             LostKeyboardFocus="Money_LostKeyboardFocus"/>

                                    </StackPanel>

                                    <!-- Comment optional -->
                                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                                        <TextBlock Text="Comment (optional)" Opacity=".7" Margin="0,0,0,6"/>
                                        <TextBox x:Name="OpeningCommentTextBox"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 md:TextFieldAssist.DecorationVisibility="Hidden"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                    </StackPanel>

                                    <!-- Buttons -->
                                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="44"
                                MinWidth="120"
                                Margin="0,0,10,0"
                                Click="OpenCashSessionCancel_Click"/>
                                        <Button x:Name="OpenCashSessionConfirmBtn"
                                Content="Open"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Height="44"
                                MinWidth="120"
                                Click="OpenCashSessionConfirm_Click"/>
                                    </StackPanel>
                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <!-- ===== SEGUNDO DialogHost (Close Cash) ===== -->
                <md:DialogHost x:Name="CloseCashHost" CloseOnClickAway="False" Grid.Row="0"  Grid.Column="0" Grid.RowSpan="99" Grid.ColumnSpan="99">

                    <!-- ===== MODAL: Close Cash ===== -->
                    <md:DialogHost.DialogContent>
                        <md:Card Width="640" Padding="24" HorizontalAlignment="Center"  VerticalAlignment="Center">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Close Cash Session"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16"/>

                                <!-- Error -->
                                <TextBlock x:Name="CloseCashErrorText"
                           Grid.Row="1"
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                                <!-- Closing cash -->
                                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                    <TextBlock Text="Closing cash" Opacity="0.7" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CloseCashAmountText"
                                         MinHeight="40"
                                         PreviewTextInput="DecimalOnly_PreviewTextInput"
                                         DataObject.Pasting="DecimalOnly_Pasting"
                                         GotKeyboardFocus="Money_GotKeyboardFocus"
                                         LostKeyboardFocus="Money_LostKeyboardFocus"/>

                                </StackPanel>

                                <!-- Comment -->
                                <StackPanel Grid.Row="3" Margin="0,0,0,16">
                                    <TextBlock Text="Comment (optional)" Opacity="0.7" Margin="0,0,0,4"/>
                                    <TextBox x:Name="ClosingCashText"
                             MinHeight="80"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Buttons -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Cancel" Margin="0,0,8,0" Click="CloseCashCancel_Click"/>
                                    <Button Content="Close session" Click="CloseCashConfirm_Click"/>
                                </StackPanel>

                            </Grid>
                        </md:Card>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <!-- ===== CASH CLOSING HISTORY DialogHost ===== -->
                <md:DialogHost x:Name="CashClosingHistoryHost"
                               CloseOnClickAway="True"
                               Grid.Row="0" Grid.Column="0"
                               Grid.RowSpan="99" Grid.ColumnSpan="99"
                               Panel.ZIndex="125">
                    <md:DialogHost.DialogContent>
                        <Grid Width="880" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="18" md:ElevationAssist.Elevation="Dp3" UniformCornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,10">
                                        <Button DockPanel.Dock="Right"
                                                Click="CloseCashClosingHistory_Click"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Height="34" MinWidth="88"
                                                Padding="14,0" Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Content="Close"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <md:PackIcon Kind="CashRegister" Width="22" Height="22" Margin="0,0,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Cash Closing History" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="CashClosingHistorySubtitle" Opacity=".65" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>

                                    <Border Grid.Row="0" BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="0,0,0,1" Margin="0,0,0,10"/>

                                    <!-- DataGrid -->
                                    <DataGrid x:Name="CashClosingHistoryGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              GridLinesVisibility="None"
                                              MaxHeight="500"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow">
                                        <DataGrid.Columns>

                                            <DataGridTextColumn Header="Opened At"
                                                Binding="{Binding OpenedAt, StringFormat={}{0:MM/dd HH:mm}}"
                                                Width="115"/>

                                            <DataGridTextColumn Header="Closed At"
                                                Binding="{Binding ClosedAt, StringFormat={}{0:HH:mm}}"
                                                Width="75"/>

                                            <DataGridTextColumn Header="Opened By"
                                                Binding="{Binding OpenedByName}"
                                                Width="*"/>

                                            <DataGridTextColumn Header="Closed By"
                                                Binding="{Binding ClosedByName}"
                                                Width="*"/>

                                            <DataGridTextColumn Header="Opening $"
                                                Binding="{Binding OpeningCash, StringFormat={}{0:N2}}"
                                                Width="90"/>

                                            <DataGridTextColumn Header="Closing $"
                                                Binding="{Binding ClosingCash, StringFormat={}{0:N2}}"
                                                Width="90"/>

                                            <DataGridTextColumn Header="Expected $"
                                                Binding="{Binding ExpectedCash, StringFormat={}{0:N2}}"
                                                Width="90"/>

                                            <DataGridTextColumn Header="Diff $"
                                                Binding="{Binding DiffCash, StringFormat={}{0:N2}}"
                                                Width="80"/>

                                            <DataGridTemplateColumn Header="" Width="105">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Click="ReprintCashClose_Click"
                                                                ToolTip="Reprint closing report"
                                                                Content="Reprint"
                                                                Padding="12,4"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                Height="32"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>

                <!-- ================== LOGOUT CONFIRM DIALOG ================== -->
                <md:DialogHost x:Name="LogoutConfirmHost" Grid.RowSpan="99" Grid.ColumnSpan="99" Panel.ZIndex="130">
                    <md:DialogHost.DialogContent>
                        <Grid Width="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:Card Padding="18" md:ElevationAssist.Elevation="Dp3" UniformCornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <md:PackIcon Kind="LogoutVariant" Width="26" Height="26"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="0,0,8,0"/>
                                        <TextBlock Text="Log off" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Message -->
                                    <TextBlock Grid.Row="1"
                               Text="Please confirm that you want to log off the current user."
                               TextWrapping="Wrap"
                               Opacity=".85"
                               Margin="0,0,0,18"/>

                                    <!-- Buttons -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="16,6"
                                Margin="0,0,8,0"
                                Click="LogoutCancel_Click"/>
                                        <Button Content="OK"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="16,6"
                                Click="LogoutConfirm_Click"/>
                                    </StackPanel>
                                </Grid>
                            </md:Card>
                        </Grid>
                    </md:DialogHost.DialogContent>
                </md:DialogHost>
            </Grid>

        </md:DrawerHost>



        <!-- ===== MODAL: Registrar chofer ===== -->
        <md:DialogHost.DialogContent>
            <md:Card Width="1020" MaxHeight="740" Padding="0" HorizontalAlignment="Center">

                <!-- ===== Estilos LOCALES (no afectan fuera del modal) ===== -->
                <md:Card.Resources>

                    <!-- Texto general más negro -->
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="#111111"/>
                        <Setter Property="FontSize" Value="14"/>
                    </Style>

                    <!-- Inputs compactos -->
                    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource FieldBox}">
                        <Setter Property="Foreground" Value="#111111"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="MinHeight" Value="40"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="md:HintAssist.Foreground" Value="#666666"/>
                    </Style>

                    <Style TargetType="{x:Type ComboBox}">
                        <Setter Property="Foreground" Value="#111111"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="MinHeight" Value="40"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="md:HintAssist.Foreground" Value="#666666"/>
                    </Style>

                    <!-- Título de sección -->
                    <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#666666"/>
                    </Style>

                    <!-- Subtítulo / helper (kept for compatibility, hidden by layout) -->
                    <Style x:Key="SectionSub" TargetType="{x:Type TextBlock}">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Foreground" Value="#888888"/>
                    </Style>

                </md:Card.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="*"/>
                        <!-- Body -->
                        <RowDefinition Height="Auto"/>
                        <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- ===== Header más marcado ===== -->
                    <Border Grid.Row="0"
                    Background="#F4F6F9"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                        <DockPanel LastChildFill="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <md:PackIcon Kind="Steering" Width="22" Height="22" Opacity="0.95" Margin="0,0,10,0"/>
                                <TextBlock x:Name="lblModalName"
                                   Text="Search driver"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="#111111"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ===== Body ===== -->
                    <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14,12"
                          Margin="0"
                          Background="White">
                        <Grid MouseDown="DialogBody_MouseDown">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ========================= SECTION: Driver information (top-left) ========================= -->
                            <Border Grid.Row="0" Grid.Column="0"
                                    CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#D9DDE3"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,6,8">
                                <StackPanel>
                                    <TextBlock Text="DRIVER INFORMATION" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                                    <!-- Phone -->
                                    <TextBox x:Name="DriverPhoneText"
                                             md:HintAssist.Hint="Phone (10 digits)"
                                             Margin="0,0,0,8"
                                             MaxLength="14"
                                             PreviewTextInput="DigitsOnly_PreviewTextInput"
                                             DataObject.Pasting="DigitsOnly_Pasting"
                                             LostFocus="DriverPhoneText_LostFocus"
                                             PreviewKeyDown="DriverPhoneText_PreviewKeyDown"/>

                                    <!-- First / Last -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ChoferNombreText"
                                                 Grid.Column="0"
                                                 md:HintAssist.Hint="{StaticResource FirstName}"
                                                 Margin="0,0,6,0"/>
                                        <TextBox x:Name="ChoferApellidosText"
                                                 Grid.Column="1"
                                                 md:HintAssist.Hint="{StaticResource LastName}"
                                                 Margin="6,0,0,0"/>
                                    </Grid>

                                    <!-- License -->
                                    <TextBox x:Name="LicenciaNumeroText"
                                             md:HintAssist.Hint="{StaticResource LicenseNo}"
                                             Margin="0,0,0,4"/>

                                    <!-- Status -->
                                    <TextBlock x:Name="DriverPhoneStatusText"
                                               Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                               Visibility="Collapsed"
                                               Text="Driver not found"/>
                                </StackPanel>
                            </Border>

                            <!-- ========================= SECTION: Business Account (top-right) ========================= -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#D9DDE3"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="6,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="BUSINESS ACCOUNT" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                                    <ComboBox x:Name="ClienteRegCombo"
                                              IsEditable="False"
                                              IsTextSearchEnabled="True"
                                              SelectionChanged="ClienteRegCombo_SelectionChanged"
                                              md:HintAssist.Hint="Company"
                                              Margin="0,0,0,8"
                                              FontSize="15"/>

                                    <TextBox x:Name="AccountNameText"
                                             IsReadOnly="True"
                                             md:HintAssist.Hint="{DynamicResource AccountName}"
                                             Margin="0,0,0,8"/>

                                    <TextBox x:Name="AccountAddressText"
                                             md:HintAssist.Hint="{DynamicResource AccountAddress}"
                                             Margin="0,0,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AccountCountryText"
                                                 Grid.Column="0"
                                                 md:HintAssist.Hint="{DynamicResource AccountCountry}"
                                                 Margin="0,0,6,0"/>
                                        <TextBox x:Name="AccountStateText"
                                                 Grid.Column="1"
                                                 md:HintAssist.Hint="{DynamicResource AccountState}"
                                                 Margin="6,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ========================= SECTION: Vehicle (bottom-left) ========================= -->
                            <Border Grid.Row="1" Grid.Column="0"
                                    CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#D9DDE3"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Unit.Section}" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                                    <!-- Plates + License State side by side -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PlacasRegText"
                                                 Grid.Column="0"
                                                 md:HintAssist.Hint="{DynamicResource Plates}"
                                                 Margin="0,0,6,0"/>
                                        <ComboBox x:Name="LicenseStateCombo"
                                                  Grid.Column="1"
                                                  IsEditable="False"
                                                  IsTextSearchEnabled="True"
                                                  md:HintAssist.Hint="{DynamicResource LicenseState}"
                                                  Margin="6,0,0,0"
                                                  FontSize="15"/>
                                    </Grid>

                                    <!-- Trailer + Tractor side by side -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TrailerNumberText"
                                                 Grid.Column="0"
                                                 md:HintAssist.Hint="{DynamicResource TrailerNumber}"
                                                 Margin="0,0,6,0"/>
                                        <TextBox x:Name="TractorNumberText"
                                                 Grid.Column="1"
                                                 md:HintAssist.Hint="{DynamicResource TractorNumber}"
                                                 Margin="6,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ========================= SECTION: Product (bottom-right) ========================= -->
                            <Border Grid.Row="1" Grid.Column="1"
                                    CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#D9DDE3"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Product}" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                                    <ComboBox x:Name="ProductoRegText"
                                              IsEditable="False"
                                              IsTextSearchEnabled="True"
                                              md:HintAssist.Hint="{DynamicResource Product}"
                                              FontSize="15"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </ScrollViewer>

                    <!-- ===== Footer fijo más claro ===== -->
                    <Border Grid.Row="2"
                    Background="#FAFBFC"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button Content="{DynamicResource Cancel}"
                                Style="{StaticResource PrimaryOutlined}"
                                Margin="0,0,10,0"
                                FontSize="14"
                                MinHeight="40"
                                MinWidth="110"
                                Click="RegisterCancel_Click"/>
                                <Button Content="{DynamicResource Save}"
                                Style="{StaticResource PrimaryRaised}"
                                FontSize="14"
                                MinHeight="40"
                                MinWidth="130"
                                Click="RegisterSave_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                </Grid>
            </md:Card>
        </md:DialogHost.DialogContent>




    </md:DialogHost>
</Window>
